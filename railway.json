{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "cd backend && gunicorn wsgi:app --bind 0.0.0.0:$PORT --workers 4 --timeout 120 --access-logfile -",
    "healthcheckPath": "/api/admin/analytics",
    "restartPolicyType": "ON_FAILURE"
  }
}
