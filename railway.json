{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": ". /opt/venv/bin/activate && cd backend && /opt/venv/bin/gunicorn wsgi:app --bind 0.0.0.0:$PORT --workers 4 --timeout 120 --access-logfile -",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
