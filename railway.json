{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "cd backend && exec /opt/venv/bin/python -m gunicorn wsgi:app --bind 0.0.0.0:$PORT --bind 0.0.0.0:3000 --workers 2 --timeout 60 --keep-alive 1 --access-logfile - --error-logfile -",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
